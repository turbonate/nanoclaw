# NanoClaw Environment Configuration

# Assistant Configuration
ASSISTANT_NAME=Andy
ASSISTANT_HAS_OWN_NUMBER=false

# API Provider Configuration (Choose ONE)
# Option 1: OpenRouter (Recommended)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1  # Optional, uses default if not set

# Option 2: Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # Optional, uses default if not set

# OAuth Configuration (Alternative to API keys)
# CLAUDE_CODE_OAUTH_TOKEN=your_oauth_token_here
# ANTHROPIC_AUTH_TOKEN=your_auth_token_here

# Container Configuration
CONTAINER_IMAGE=nanoclaw-agent:latest
CONTAINER_TIMEOUT=1800000
CONTAINER_MAX_OUTPUT_SIZE=10485760
CREDENTIAL_PROXY_PORT=3001
IDLE_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5

# Timezone Configuration
TZ=America/New_York

# Note: Create a .env file from this template and fill in your actual API keys
# Only configure ONE API provider (OpenRouter OR Anthropic)
